# === 小膳 Shanbot 環境變數 ===
# 複製此檔案為 .env 並填入你的金鑰：cp .env.example .env

# === LINE Bot（必填）===
# 至 LINE Developers Console 取得：https://developers.line.biz/console/
LINE_CHANNEL_ID=your_channel_id_here
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# === AI / LLM（必填）===
# Gemini API Key：至 Google AI Studio 免費取得 https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# LLM Router（選填，自建 LLM 路由服務）
LLM_ROUTER_URL=http://127.0.0.1:8010/chat

# === OCR 備援引擎（選填）===
# HunyuanOCR：至 https://huggingface.co/settings/tokens 取得 token
HUNYUAN_OCR_API_KEY=your_huggingface_token_here
HUNYUAN_OCR_API_URL=https://router.huggingface.co/hf-inference/models/tencent/HunyuanOCR

# === 電子發票驗證 API（選填）===
# 至 https://www.einvoice.nat.gov.tw 申請 API
EINVOICE_APP_ID=
EINVOICE_API_KEY=

# === Google Drive 歸檔（選填）===
# 安裝 Google Drive 桌面版後的本地掛載路徑
GDRIVE_LOCAL=/path/to/your/gdrive/mount

# === 公司資訊（選填，用於稅務匯出和報表）===
COMPANY_TAX_ID=your_tax_id_here
COMPANY_TAX_REG_NO=your_tax_reg_no_here
COMPANY_NAME=your_company_name_here

# === 公開 URL（選填）===
# Cloudflare Tunnel 或 ngrok 的公開 HTTPS 網址，用於 LINE 圖片回傳
PUBLIC_BASE_URL=https://your-domain.example.com

# === 服務設定（選填）===
PORT=8025
DB_PATH=./data/shanbot.db
LOG_LEVEL=INFO
